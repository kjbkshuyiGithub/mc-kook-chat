{
	"schemaVersion": 1,
	"id": "mc-kook-chat",
	"version": "${version}",
	"name": "McKookChat",
	"description": "A Fabric mod that bridges Minecraft server chat with KooK platform.",
	"authors": [
		"McBlocker"
	],
	"contributors": [
		"shuaihanya",
		"HaiCheng MTR Server Team"
	],
	"contact": {
		"homepage": "https://github.com/kjbkshuyiGithub/mc-kook-chat",
		"sources": "https://github.com/kjbkshuyiGithub/mc-kook-chat",
		"issues": "https://github.com/kjbkshuyiGithub/mc-kook-chat/issues"
	},
	"license": "Apache-2.0",
	"icon": "assets/mc-kook-chat/icon.png",
	"environment": "*",
	"entrypoints": {
		"main": [
			"haicheng.mckookchat.McKookChat"
		],
		"client": [
			"haicheng.mckookchat.McKookChatClient"
		],
		"fabric-datagen": [
			"haicheng.mckookchat.McKookChatDataGenerator"
		]
	},
	"mixins": [
		"mc-kook-chat.mixins.json",
		{
			"config": "mc-kook-chat.client.mixins.json",
			"environment": "client"
		}
	],
	"depends": {
		"fabricloader": ">=0.18.5",
		"minecraft": "~1.20.1",
		"java": ">=17",
		"fabric-api": "*"
	}
}